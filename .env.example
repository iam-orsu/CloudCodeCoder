# ===========================================
# Cloud Code — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Usage: cp .env.example .env && nano .env

# --- Ports (change if you have conflicts) ---
WEB_PORT=3080
CODER_PORT=7080

# --- Database ---
DB_PASSWORD=changeme
DATABASE_URL="postgresql://cloudcode:changeme@db:5432/cloudcode?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3080"
NEXTAUTH_SECRET="generate-a-random-secret-run-openssl-rand-base64-32"

# --- GitHub OAuth ---
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3080/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Coder ---
CODER_URL="http://coder:7080"
CODER_ACCESS_URL="http://localhost:7080"
CODER_API_TOKEN=""
CODER_ORG_ID="default"
CODER_TEMPLATE_NAME="azure-linux"

# --- Azure (used by Coder for VM provisioning) ---
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_SUBSCRIPTION_ID=""
AZURE_TENANT_ID=""

# --- Redis ---
REDIS_URL="redis://redis:6379"
