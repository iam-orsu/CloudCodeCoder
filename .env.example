# ===========================================
# Cloud Code — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Usage: cp .env.example .env && nano .env

# --- Ports (change if you have conflicts) ---
WEB_PORT=3080
CODER_PORT=7080

# --- Public Host (Required for Production) ---
# Replace with your VPS's public IPv4 address (e.g., "http://203.0.113.50")
# Do NOT include a trailing slash.
NEXT_PUBLIC_APP_URL="http://YOUR_VPS_IP:3080"
NEXT_PUBLIC_CODER_URL="http://YOUR_VPS_IP:7080"

# --- NextAuth ---
# Create Github OAuth App at: https://github.com/settings/applications/new
# Callback URL: http://YOUR_VPS_IP:3080/api/auth/callback/github
NEXTAUTH_URL="${NEXT_PUBLIC_APP_URL}"
NEXTAUTH_SECRET="generate-a-random-secret-run-openssl-rand-base64-32"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Coder ---
CODER_ACCESS_URL="${NEXT_PUBLIC_CODER_URL}"
CODER_URL="http://coder:7080" # Internal Docker routing
CODER_API_TOKEN=""
CODER_ORG_ID="default"
CODER_TEMPLATE_NAME="azure-linux"

# --- Database ---
DB_PASSWORD=changeme
DATABASE_URL="postgresql://cloudcode:changeme@db:5432/cloudcode?schema=public"

# --- Azure (used by Coder for VM provisioning) ---
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_SUBSCRIPTION_ID=""
AZURE_TENANT_ID=""

# --- Redis ---
REDIS_URL="redis://redis:6379"
